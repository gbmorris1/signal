# Signal environment.
# HOW TO USE: copy this file to `.env` (same folder) and fill in the values.
#   cp .env.example .env
# `.env` is git-ignored. Expo loads it automatically; app.config.js reads these
# into the app. With no `.env`, the app runs fully on mock data.

# ── Client-safe keys (these DO ship in the app — that's fine, they're public) ──

# Supabase — Settings → API in your project dashboard
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# RevenueCat — Project → API keys → "Public app-specific" iOS key
EXPO_PUBLIC_REVENUECAT_IOS_KEY=

# Optional flags. If you set EXPO_PUBLIC_SUPABASE_URL above, live mode turns on
# automatically. Uncomment to force a mode.
# EXPO_PUBLIC_USE_MOCK_DATA=false
# EXPO_PUBLIC_USE_LIVE_DATA=true

# ─────────────────────────────────────────────────────────────────────────────
# SECRET keys do NOT go here. They never touch the app or the repo.
# Set them on Supabase instead (see docs/SETUP_KEYS.md):
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# The Supabase service_role key is injected into deployed Edge Functions
# automatically — you never paste it anywhere.
